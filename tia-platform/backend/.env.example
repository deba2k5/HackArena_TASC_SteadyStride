DATABASE_URL=postgresql+asyncpg://tia_user:tia_pass@localhost:5432/tia_db
SYNC_DATABASE_URL=postgresql://tia_user:tia_pass@localhost:5432/tia_db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
UPLOAD_DIR=./uploads
LAYOUTLMV3_MODEL=microsoft/layoutlmv3-base
TESSERACT_CMD=/usr/bin/tesseract
CONFIDENCE_THRESHOLD=0.75
FRAUD_RISK_THRESHOLD=0.65
MAX_UPLOAD_SIZE_MB=50
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
ENVIRONMENT=development
LOG_LEVEL=INFO
